{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://integral-notes.local/schemas/integral-plugin.schema.json",
  "title": "IntegralNotes Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "description",
    "displayName",
    "id",
    "namespace",
    "version"
  ],
  "anyOf": [
    {
      "required": [
        "blocks"
      ]
    },
    {
      "required": [
        "viewers"
      ]
    },
    {
      "required": [
        "sidebarViews"
      ]
    }
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry",
        "mode"
      ],
      "properties": {
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "const": "iframe"
        }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry",
        "runtime"
      ],
      "properties": {
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "type": "string",
          "const": "module"
        }
      }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "title",
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "busyLabel",
                "id",
                "label"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "busyLabel": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "viewers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "displayName",
          "extensions",
          "id",
          "renderer"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "extensions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "renderer": {
            "$ref": "#/properties/renderer"
          }
        }
      }
    },
    "sidebarViews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "id",
          "renderer",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string",
            "minLength": 1
          },
          "renderer": {
            "$ref": "#/properties/renderer"
          }
        }
      }
    }
  }
}
