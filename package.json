{
  "name": "integral-notes-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "IntegralNotes prototype built with Electron, React, Milkdown, and FlexLayout.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "node src/dev/dev-supervisor.cjs",
    "dev:renderer": "node src/dev/start-renderer.cjs",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://127.0.0.1:5173 dist-electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist-electron/main --ext js,mjs,cjs --exec \"electron dist-electron/main/main.js\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "plugins:package:shimadzu-lc": "node src/dev/plugin-package-builder.mjs package plugins/shimadzu-lc",
    "plugins:package:standard-graphs": "node src/dev/plugin-package-builder.mjs package plugins/standard-graphs",
    "plugins:package:all": "node src/dev/plugin-package-builder.mjs package plugins/shimadzu-lc plugins/standard-graphs",
    "plugins:where": "node src/dev/plugin-installer.mjs where",
    "plugins:install:all": "node src/dev/plugin-installer.mjs install plugins/shimadzu-lc plugins/standard-graphs",
    "plugins:uninstall:all": "node src/dev/plugin-installer.mjs uninstall plugins/shimadzu-lc plugins/standard-graphs",
    "start": "electron dist-electron/main/main.js",
    "dist:win": "npm run build && electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "com.shimadzu.integralnotes",
    "productName": "IntegralNotes",
    "artifactName": "IntegralNotes-Setup-${version}.${ext}",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "win": {
      "signAndEditExecutable": false,
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@milkdown/crepe": "^7.17.1",
    "@milkdown/plugin-listener": "^7.17.1",
    "flexlayout-react": "^0.8.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.9",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "wait-on": "^8.0.2"
  }
}
