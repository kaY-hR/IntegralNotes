{
  "name": "integral-notes-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "IntegralNotes prototype built with Electron, React, Milkdown, and FlexLayout.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "node src/dev/ensure-local-dev-config.cjs && node src/dev/dev-supervisor.cjs",
    "dev:renderer": "node src/dev/ensure-local-dev-config.cjs && node src/dev/start-renderer.cjs",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://127.0.0.1:5173 dist-electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist-electron/main --ext js,mjs,cjs --exec \"electron dist-electron/main/main.js\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "plugins:package:shimadzu-lc": "node src/dev/plugin-package-builder.mjs package plugins/shimadzu-lc",
    "plugins:package:image-compare-viewer": "node src/dev/plugin-package-builder.mjs package plugins/image-compare-viewer",
    "plugins:package:all": "node src/dev/plugin-package-builder.mjs package plugins/shimadzu-lc plugins/image-compare-viewer",
    "plugins:where": "node src/dev/plugin-installer.mjs where",
    "plugins:install:all": "node src/dev/plugin-installer.mjs install plugins/shimadzu-lc plugins/image-compare-viewer",
    "plugins:uninstall:all": "node src/dev/plugin-installer.mjs uninstall plugins/shimadzu-lc plugins/image-compare-viewer",
    "mcp:playwright": "node src/dev/integral-playwright-mcp.mjs",
    "start": "electron dist-electron/main/main.js",
    "dist:win": "npm run build && electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "com.shimadzu.integralnotes",
    "productName": "IntegralNotes",
    "artifactName": "IntegralNotes-Setup-${version}.${ext}",
    "directories": {
      "output": "out"
    },
    "extraResources": [
      {
        "from": "Notes",
        "to": "workspace-template"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "win": {
      "signAndEditExecutable": false,
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@milkdown/crepe": "^7.17.1",
    "@milkdown/plugin-listener": "^7.17.1",
    "ai": "^6.0.168",
    "bash-tool": "^1.3.16",
    "flexlayout-react": "^0.8.17",
    "graphology": "^0.26.0",
    "just-bash": "^2.14.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sigma": "^3.0.3",
    "sql.js": "^1.14.1",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.9",
    "playwright-core": "^1.59.1",
    "typescript": "^5.7.3",
    "vite": "^8.0.10",
    "wait-on": "^8.0.2"
  }
}
