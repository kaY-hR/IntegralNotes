{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "src",
    "types": [
      "node",
      "electron"
    ],
    "esModuleInterop": true
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*"
  ]
}
