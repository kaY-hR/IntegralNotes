{
  "apiVersion": "1",
  "id": "shimadzu-lc",
  "namespace": "shimadzu-lc",
  "displayName": "Shimadzu LC",
  "version": "0.1.0",
  "description": "LC sequence 系 block を提供する plugin",
  "renderer": {
    "entry": "renderer/index.html",
    "mode": "iframe"
  },
  "host": {
    "entry": "host/index.cjs",
    "runtime": "module"
  },
  "blocks": [
    {
      "type": "run-sequence",
      "title": "LC Linear Gradient",
      "description": "勾配プログラムを編集し、LC シーケンスを実行する。",
      "actions": [
        {
          "id": "execute",
          "label": "装置操作を実行",
          "busyLabel": "装置操作を送信中..."
        }
      ]
    }
  ]
}
